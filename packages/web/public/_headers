/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(self)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://maps.googleapis.com https://maps.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://maps.googleapis.com; img-src 'self' https://*.basemaps.cartocdn.com https://*.tile.openstreetmap.org https://openweathermap.org https://maps.googleapis.com https://maps.gstatic.com https://*.google.com https://*.ggpht.com data: blob:; connect-src 'self' https://*.railway.app wss://*.railway.app https://api.openweathermap.org https://*.basemaps.cartocdn.com https://*.tile.openstreetmap.org https://maps.googleapis.com https://maps.gstatic.com https://*.google.com https://*.googleapis.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com data:; worker-src 'self' blob:; frame-src 'self' https://maps.googleapis.com https://maps.gstatic.com; object-src 'none';

# 해시 없는 index.html은 캐시 금지 — 재배포 시 stale chunk 에러 원천 차단
/
  Cache-Control: no-store, must-revalidate
/index.html
  Cache-Control: no-store, must-revalidate

# 해시된 에셋(.js/.css/.png 등)은 immutable — 파일명이 바뀌므로 안전하게 장기 캐시
/assets/*
  Cache-Control: public, max-age=31536000, immutable
