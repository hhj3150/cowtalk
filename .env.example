# ======================================================================
# CowTalk v5.0 환경변수 (.env.example)
# 이 파일을 .env로 복사한 후 실제 값을 설정하세요.
# ======================================================================

# --- 서버 ---
NODE_ENV=development
PORT=4000

# --- PostgreSQL + TimescaleDB ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cowtalk
DB_USER=cowtalk
DB_PASSWORD=cowtalk_dev_2025

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT 인증 ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- smaXtec API ---
SMAXTEC_API_URL=https://api.smaxtec.com/api/v2
SMAXTEC_EMAIL=
SMAXTEC_PASSWORD=
SMAXTEC_ORG_ID=

# --- Anthropic Claude API (CowTalk Chat) ---
ANTHROPIC_API_KEY=

# --- 공공데이터 API ---
PUBLIC_DATA_API_KEY=
PUBLIC_DATA_BASE_URL=

# --- 날씨 API ---
WEATHER_API_KEY=
WEATHER_API_URL=

# --- 알림 (이메일/SMS) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMS_API_KEY=
SMS_SENDER=

# --- 프론트엔드 (VITE_ 접두사만 클라이언트 노출) ---
VITE_API_BASE_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000

# --- 로깅 ---
LOG_LEVEL=debug
