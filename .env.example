# ======================================================================
# CowTalk v5.0 환경변수 (.env.example)
# 이 파일을 .env로 복사한 후 실제 값을 설정하세요.
# ======================================================================

# --- 서버 ---
NODE_ENV=development
PORT=4000

# --- PostgreSQL + TimescaleDB ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cowtalk
DB_USER=cowtalk
DB_PASSWORD=cowtalk_dev_2025

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT 인증 ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- smaXtec API ---
SMAXTEC_API_URL=https://api.smaxtec.com/api/v2
SMAXTEC_EMAIL=
SMAXTEC_PASSWORD=
SMAXTEC_ORG_ID=

# --- Anthropic Claude API (CowTalk Chat) ---
ANTHROPIC_API_KEY=

# --- OpenAI TTS (팅커벨 음성 답변) ---
# 키 발급: platform.openai.com → API keys (Audio 권한만 부여 권장)
# 기본값: tts-1 모델 + Nova 음성 + 앞 500자만 합성 (비용 절감)
OPENAI_API_KEY=
# OPENAI_TTS_MODEL=tts-1          # tts-1 ($15/1M자) 또는 tts-1-hd ($30/1M자)
# OPENAI_TTS_VOICE=nova           # nova/shimmer/alloy/fable/onyx/echo
# OPENAI_TTS_MAX_CHARS=500        # 응답 앞 N자만 합성 (50~4000)

# --- 공공데이터 API ---
PUBLIC_DATA_API_KEY=
PUBLIC_DATA_BASE_URL=

# --- 날씨 API ---
WEATHER_API_KEY=
WEATHER_API_URL=

# --- 알림 (이메일/SMS) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMS_API_KEY=
SMS_SENDER=

# --- 프론트엔드 (VITE_ 접두사만 클라이언트 노출) ---
VITE_API_BASE_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000

# --- 로깅 ---
LOG_LEVEL=debug
